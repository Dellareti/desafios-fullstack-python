# Configurações do Browser
HEADLESS=true

# Timeout máximo por consulta em milissegundos
TIMEOUT_MS=30000

# Nível de log: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Porta da API
PORT=8000

# Configurações CORS (origens separadas por vírgula)
CORS_ORIGINS=*

# Número máximo de instâncias simultâneas do browser
MAX_BROWSER_INSTANCES=5

# Rate limit: máximo de requisições por minuto por IP
RATE_LIMIT_PER_MINUTE=10
